<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
  <!-- Configuración para desarrollo: permite HTTP y certificados autofirmados -->
  <!-- ⚠️ IMPORTANTE: En producción, quitar cleartextTrafficPermitted y usar solo HTTPS válido -->
  <base-config cleartextTrafficPermitted="true">
    <trust-anchors>
      <certificates src="system" />
      <certificates src="user" />
    </trust-anchors>
  </base-config>
  
  <!-- Configuración específica para localhost y red local -->
  <domain-config cleartextTrafficPermitted="true">
    <domain includeSubdomains="true">localhost</domain>
    <domain includeSubdomains="true">10.0.2.2</domain>
    <domain includeSubdomains="true">127.0.0.1</domain>
    <domain includeSubdomains="true">10.40.27.118</domain>
    <trust-anchors>
      <certificates src="system" />
      <certificates src="user" />
    </trust-anchors>
  </domain-config>
</network-security-config>
