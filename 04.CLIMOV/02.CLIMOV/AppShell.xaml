<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="_02.CLIMOV.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:_02.CLIMOV"
    xmlns:vista="clr-namespace:_02.CLIMOV.Vista"
    Title="Conversion App"
    Shell.FlyoutBehavior="Disabled">

    <!-- Página de Login -->
    <ShellContent
        Title="Login"
        ContentTemplate="{DataTemplate vista:LoginPage}"
        Route="LoginPage" />

    <!-- Página de Conversión -->
    <ShellContent
        Title="Conversión"
        ContentTemplate="{DataTemplate vista:ConversionPage}"
        Route="ConversionPage" />

</Shell>
