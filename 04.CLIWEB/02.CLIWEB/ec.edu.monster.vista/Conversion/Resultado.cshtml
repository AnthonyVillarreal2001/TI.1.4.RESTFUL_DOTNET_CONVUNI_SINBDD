@model _04.CLIWEB.ec.edu.monster.modelo.Resultado

@{
    ViewData["Title"] = "Resultado de Conversión";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
        }
        .result-card {
            backdrop-filter: blur(10px);
            background: rgba(255, 255, 255, 0.98);
            animation: slideUp 0.5s ease-out;
        }
        @@keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        @@keyframes pulse-success {
            0%, 100% {
                transform: scale(1);
            }
            50% {
                transform: scale(1.1);
            }
        }
        .pulse-success {
            animation: pulse-success 2s ease-in-out infinite;
        }
        .btn-action {
            transition: all 0.3s ease;
        }
        .btn-action:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        }
        .copy-btn:active {
            transform: scale(0.95);
        }
    </style>
</head>
<body class="flex items-center justify-center min-h-screen p-4">
    <div class="max-w-2xl w-full">
        <!-- Success Icon -->
        <div class="text-center mb-6">
            <div class="inline-flex items-center justify-center w-24 h-24 bg-white rounded-full shadow-2xl pulse-success mb-4">
                <i class="fas fa-check-circle text-green-500 text-5xl"></i>
            </div>
            <h1 class="text-3xl font-bold text-white mb-2">
                <i class="fas fa-star mr-2"></i>¡Conversión Exitosa!
            </h1>
            <p class="text-purple-100">Tu conversión se ha realizado correctamente</p>
        </div>

        <!-- Result Card -->
        <div class="result-card rounded-3xl shadow-2xl p-8 mb-6">
            <!-- Header -->
            <div class="text-center mb-6">
                <div class="inline-flex items-center justify-center bg-gradient-to-br from-purple-500 to-purple-700 px-6 py-2 rounded-full mb-4">
                    <i class="fa-brands fa-microsoft text-white text-xl mr-2"></i>
                    <span class="text-white font-semibold">.NET Converter</span>
                </div>
                <h2 class="text-xl font-bold text-gray-700 mb-1">Tipo de Conversión</h2>
                <p class="text-3xl font-bold text-purple-600">@Model.Type</p>
            </div>

            <div class="border-t-2 border-gray-200 my-6"></div>

            <!-- Conversion Display -->
            <div class="space-y-6">
                <!-- Input Value -->
                <div class="bg-gradient-to-r from-gray-50 to-gray-100 rounded-2xl p-6 border-l-4 border-purple-500">
                    <div class="flex items-center justify-between">
                        <div class="flex-1">
                            <p class="text-sm text-gray-600 mb-2 flex items-center gap-2">
                                <i class="fas fa-arrow-down text-purple-600"></i>
                                <span class="font-semibold">Valor de Entrada</span>
                            </p>
                            <p class="text-3xl font-bold text-gray-800">@Model.Input</p>
                        </div>
                        <button onclick="copyToClipboard('@Model.Input')" class="copy-btn p-3 bg-purple-100 hover:bg-purple-200 rounded-xl transition-all">
                            <i class="fas fa-copy text-purple-600 text-xl"></i>
                        </button>
                    </div>
                </div>

                <!-- Arrow -->
                <div class="text-center">
                    <div class="inline-flex items-center justify-center w-16 h-16 bg-gradient-to-br from-purple-500 to-purple-700 rounded-full shadow-lg">
                        <i class="fas fa-arrow-down text-white text-2xl"></i>
                    </div>
                </div>

                <!-- Output Value -->
                <div class="bg-gradient-to-r from-purple-50 to-purple-100 rounded-2xl p-6 border-l-4 border-green-500">
                    <div class="flex items-center justify-between">
                        <div class="flex-1">
                            <p class="text-sm text-gray-600 mb-2 flex items-center gap-2">
                                <i class="fas fa-arrow-up text-green-600"></i>
                                <span class="font-semibold">Valor Convertido</span>
                            </p>
                            <p class="text-4xl font-bold text-purple-600">@Model.Output</p>
                        </div>
                        <button onclick="copyToClipboard('@Model.Output')" class="copy-btn p-3 bg-green-100 hover:bg-green-200 rounded-xl transition-all">
                            <i class="fas fa-copy text-green-600 text-xl"></i>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Info Box -->
            <div class="mt-6 bg-blue-50 border-l-4 border-blue-500 p-4 rounded-lg">
                <div class="flex items-start">
                    <i class="fas fa-info-circle text-blue-600 mt-1 mr-3 text-xl"></i>
                    <div class="text-sm text-gray-700">
                        <p class="font-semibold mb-1">Información de la conversión:</p>
                        <p>Los resultados son calculados por nuestro servidor .NET REST API con precisión matemática.</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="grid md:grid-cols-2 gap-4 mb-6">
            <a href="/Conversion/Index" class="btn-action bg-white text-purple-700 font-bold py-4 rounded-xl flex items-center justify-center gap-3 shadow-lg hover:shadow-xl">
                <i class="fas fa-sync-alt"></i>
                <span>Nueva Conversión</span>
            </a>
            <button onclick="shareResult()" class="btn-action bg-gradient-to-r from-purple-600 to-purple-800 text-white font-bold py-4 rounded-xl flex items-center justify-center gap-3 shadow-lg hover:shadow-xl">
                <i class="fas fa-share-alt"></i>
                <span>Compartir Resultado</span>
            </button>
        </div>

        <!-- Additional Actions -->
        <div class="flex justify-center gap-4">
            <button onclick="printResult()" class="text-white hover:text-purple-200 transition-colors flex items-center gap-2">
                <i class="fas fa-print"></i>
                <span>Imprimir</span>
            </button>
            <span class="text-white">|</span>
            <a href="/Login/Logout" class="text-white hover:text-purple-200 transition-colors flex items-center gap-2">
                <i class="fas fa-sign-out-alt"></i>
                <span>Cerrar Sesión</span>
            </a>
        </div>

        <!-- Footer -->
        <div class="text-center mt-8 text-purple-100 text-sm">
            <p>
                <i class="fa-brands fa-microsoft mr-2"></i>
                Powered by ASP.NET Core 8.0 REST API
            </p>
        </div>
    </div>

    <script>
        function copyToClipboard(text) {
            navigator.clipboard.writeText(text).then(() => {
                Toastify({
                    text: "✓ Copiado al portapapeles",
                    duration: 2000,
                    gravity: "top",
                    position: "right",
                    style: {
                        background: "linear-gradient(135deg, #10b981 0%, #059669 100%)",
                        borderRadius: "12px",
                        padding: "12px 20px",
                        fontWeight: "600"
                    }
                }).showToast();
            });
        }

        function shareResult() {
            const text = `Conversión realizada: @Model.Input → @Model.Output (@Model.Type)`;
            if (navigator.share) {
                navigator.share({
                    title: 'Resultado de Conversión',
                    text: text
                });
            } else {
                copyToClipboard(text);
                Toastify({
                    text: "📋 Resultado copiado para compartir",
                    duration: 3000,
                    gravity: "top",
                    position: "center",
                    style: {
                        background: "linear-gradient(135deg, #3b82f6 0%, #2563eb 100%)",
                        borderRadius: "12px",
                        padding: "16px 24px",
                        fontWeight: "600"
                    }
                }).showToast();
            }
        }

        function printResult() {
            window.print();
        }

        // Mostrar notificación de éxito al cargar
        window.addEventListener('load', function() {
            Toastify({
                text: "✓ ¡Conversión completada con éxito!",
                duration: 3000,
                gravity: "top",
                position: "right",
                style: {
                    background: "linear-gradient(135deg, #10b981 0%, #059669 100%)",
                    borderRadius: "12px",
                    padding: "16px 24px",
                    fontWeight: "600",
                    boxShadow: "0 10px 25px rgba(16, 185, 129, 0.3)"
                }
            }).showToast();
        });
    </script>
</body>
</html>
